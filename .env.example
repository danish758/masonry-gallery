# Pixabay API key (free): https://pixabay.com/api/docs/
# 1. Create a free Pixabay account and log in
# 2. Your API key is shown on the API docs page (under "Parameters")
# 3. Copy this file to ".env.local" and paste your key below
# 4. Restart the dev server
# Free limit: 100 requests/minute
VITE_PIXABAY_API_KEY=your_api_key_here
